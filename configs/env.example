# =============================================================================
# Honcho Local Instance — Ollama Cloud Configuration
# =============================================================================

LOG_LEVEL=INFO

# =============================================================================
# Database (Docker internal)
# =============================================================================
DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@database:5432/postgres

# =============================================================================
# Authentication — disable for local, enable for Tailscale multi-machine
# =============================================================================
AUTH_USE_AUTH=false
# AUTH_JWT_SECRET=generate-a-secret-here

# =============================================================================
# LLM Provider — Ollama Cloud (OpenAI-compatible)
# =============================================================================
# Replace with your Ollama Cloud endpoint and API key
# Find your API key at: https://ollama.com/settings/keys
LLM_OPENAI_COMPATIBLE_BASE_URL=https://ollama.com/v1
LLM_OPENAI_COMPATIBLE_API_KEY=your-ollama-cloud-api-key-here

# Embedding — routed to LOCAL Ollama (faster, free, no cloud roundtrip)
LLM_EMBEDDING_PROVIDER=openrouter
LLM_EMBEDDING_MODEL=bge-m3
# host.docker.internal resolves to the Docker host where local Ollama runs
LLM_EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1

# =============================================================================
# Deriver (Background memory extraction)
# =============================================================================
DERIVER_PROVIDER=custom
DERIVER_MODEL=qwen3.5:397b
# DERIVER_THINKING_BUDGET_TOKENS=1024
# Process messages immediately instead of waiting for token threshold
DERIVER_FLUSH_ENABLED=true

# =============================================================================
# Summary
# =============================================================================
SUMMARY_PROVIDER=custom
SUMMARY_MODEL=qwen3.5:397b
# SUMMARY_THINKING_BUDGET_TOKENS=512

# =============================================================================
# Dialectic (Memory recall/synthesis)
# =============================================================================
# Minimal/Low — fast model for quick lookups
DIALECTIC_LEVELS__minimal__PROVIDER=custom
DIALECTIC_LEVELS__minimal__MODEL=qwen3.5:397b
DIALECTIC_LEVELS__minimal__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__minimal__MAX_TOOL_ITERATIONS=1
DIALECTIC_LEVELS__minimal__MAX_OUTPUT_TOKENS=250

DIALECTIC_LEVELS__low__PROVIDER=custom
DIALECTIC_LEVELS__low__MODEL=qwen3.5:397b
DIALECTIC_LEVELS__low__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__low__MAX_TOOL_ITERATIONS=5

# Medium/High/Max — smart model for deep reasoning
DIALECTIC_LEVELS__medium__PROVIDER=custom
DIALECTIC_LEVELS__medium__MODEL=minimax-m2.7
DIALECTIC_LEVELS__medium__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__medium__MAX_TOOL_ITERATIONS=2

DIALECTIC_LEVELS__high__PROVIDER=custom
DIALECTIC_LEVELS__high__MODEL=minimax-m2.7
DIALECTIC_LEVELS__high__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__high__MAX_TOOL_ITERATIONS=4

DIALECTIC_LEVELS__max__PROVIDER=custom
DIALECTIC_LEVELS__max__MODEL=minimax-m2.7
DIALECTIC_LEVELS__max__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__max__MAX_TOOL_ITERATIONS=10

# =============================================================================
# Dream (Memory consolidation — runs every 8h)
# =============================================================================
DREAM_ENABLED=true
DREAM_PROVIDER=custom
DREAM_MODEL=minimax-m2.7
DREAM_DEDUCTION_MODEL=qwen3.5:397b
DREAM_INDUCTION_MODEL=qwen3.5:397b
# DREAM_THINKING_BUDGET_TOKENS=8192
DREAM_MIN_HOURS_BETWEEN_DREAMS=8
DREAM_DOCUMENT_THRESHOLD=50
DREAM_IDLE_TIMEOUT_MINUTES=60
DREAM_MAX_TOOL_ITERATIONS=20

# =============================================================================
# Cache (Redis)
# =============================================================================
CACHE_ENABLED=true
CACHE_URL=redis://redis:6379/0?suppress=true

# =============================================================================
# Vector Store
# =============================================================================
VECTOR_STORE_TYPE=pgvector
# bge-m3: 1024 dims, 72% RAG accuracy, MIT license
VECTOR_STORE_DIMENSIONS=1024
